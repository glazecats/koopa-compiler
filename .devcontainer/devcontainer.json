{
  "name": "Koopa Compiler Dev",
  "image": "maxxing/compiler-dev",
  "runArgs": [
    "--security-opt", "seccomp=unconfined",
    "--security-opt", "apparmor=unconfined",
    "--cap-add=SYS_ADMIN",
    "-e", "IKUN",
    "-e", "ikun"
  ],
  "containerEnv": {
    "IKUN": "${localEnv:IKUN}",
    "ikun": "${localEnv:IKUN}"
  },
  "remoteEnv": {
    "IKUN": "${localEnv:IKUN}",
    "ikun": "${localEnv:IKUN}"
  },
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.makefile-tools",
        "openai.chatgpt"
      ]
    }
  },
  "mounts": [
      "source=codex-home,target=/root/.codex,type=volume"
  ]
}
